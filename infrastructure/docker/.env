# Docker Compose Environment Configuration
COMPOSE_PROJECT_NAME=aiva

# Database
POSTGRES_USER=aiva
POSTGRES_PASSWORD=aiva-secret-change-in-production
POSTGRES_DB=aiva
POSTGRES_VERSION=15-alpine

# Redis
REDIS_VERSION=7-alpine

# Application
NODE_ENV=production
PORT=4000

# AI Services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-5-20250929

# JWT
JWT_SECRET=generate-a-secure-random-string-for-production
